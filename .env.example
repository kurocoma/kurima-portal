# くりまポータルツール 環境変数サンプル
#
# 使い方: このファイルを .env にコピーして実値を設定する。
#   copy .env.example .env
# .env は .gitignore 済みで、コミットされない。実値をこのファイルに書かないこと。
# アプリ起動時に portal_tool/.env（および .env.yamato-b2 / yamato-b2.env）を自動で読み込む。

# ---------------------------------------------------------------
# パス設定（SharePoint / OneDrive 同期フォルダ）
# 未設定なら「%USERPROFILE%\株式会社しまのや\くりまポータル - ドキュメント」等を自動探索する。
# 他のPCで同期先が異なる場合のみ設定すればよい。
# ---------------------------------------------------------------

# ポータルルート（「商品管理シート.xlsm」と「ネクストエンジン\発注関連\受注明細一覧」がある同期フォルダ）
#KURIMA_PORTAL_ROOT=C:\Users\<ユーザー名>\株式会社しまのや\くりまポータル - ドキュメント

# 旧キー（KURIMA_PORTAL_ROOT と同じ意味。後方互換のため残している）
#PORTAL_ROOT=C:\Users\<ユーザー名>\株式会社しまのや\くりまポータル - ドキュメント

# 商品管理シート.xlsm の場所を個別に上書きしたい場合のみ設定
#KURIMA_MASTER_BOOK=C:\path\to\商品管理シート.xlsm

# 受注明細CSV（data*.csv）フォルダを個別に上書きしたい場合のみ設定
#KURIMA_ORDER_CSV_DIR=C:\path\to\ネクストエンジン\発注関連\受注明細一覧

# ツール類（高江洲発注書などの出力先）フォルダを個別に上書きしたい場合のみ設定
#KURIMA_TOOL_DIR=C:\path\to\ネクストエンジン\発注関連

# 実行ログ・エラーログ（portal-run.log / portal-error.log）の出力先を上書きしたい場合のみ設定。
# 未設定なら「%USERPROFILE%\株式会社しまのや\くりまポータル - ドキュメント\神里\くりまポータルエラーログ」
# へ出力する（フォルダが無ければ自動作成。同期フォルダが無いPCは logs/ に fallback）。
#KURIMA_LOG_DIR=C:\path\to\log-folder

# ---------------------------------------------------------------
# サーバー設定
# ---------------------------------------------------------------

# scripts/serve.ps1 が使う既定ポート（未設定なら 8006）
#KURIMA_PORT=8006

# ---------------------------------------------------------------
# Next Engine 認証（Playwright 自動操作用）
# LOGIN_ID/PASSWORD を設定するか、認証情報Excel のパスを指定する。
# ---------------------------------------------------------------

NEXT_ENGINE_LOGIN_ID=your_next_engine_login_id
NEXT_ENGINE_PASSWORD=your_next_engine_password

# LOGIN_ID/PASSWORD 未設定時に参照する認証情報Excel（A列=サイト名, B列=ID, C列=PW）
#NEXT_ENGINE_CREDENTIAL_PATH=C:\path\to\ID・PW.xlsx

# Next Engine 操作をヘッドレスで実行するか（true/false。既定 true）
#NEXT_ENGINE_HEADLESS=true

# Playwright 同梱ブラウザの代わりに使う Chrome/Edge の実行ファイル（通常は不要）
#PLAYWRIGHT_CHROMIUM_EXECUTABLE=C:\Program Files\Google\Chrome\Application\chrome.exe

# ---------------------------------------------------------------
# ヤマトB2クラウド 認証
# ---------------------------------------------------------------

# お客様コード(12桁) と パスワード。メンバーズのログイン画面 #code1 / #password に入力される。
YAMATO_B2_LOGIN_ID=your_yamato_b2_login_id
YAMATO_B2_PASSWORD=your_yamato_b2_password

# お客様コードの分類コード(3桁, #code2) と 個人ID(#kojin)。契約で必要な場合のみ設定（既定は未設定=入力しない）。
#YAMATO_B2_CLASS_CODE=000
#YAMATO_B2_PERSONAL_ID=your_yamato_b2_personal_id

# B2クラウド入口URLを上書きしたい場合のみ設定（通常は不要。既定はコード内の DEFAULT_YAMATO_B2_URL）
#YAMATO_B2_URL=https://example.invalid/your-b2-entry-url

# ログイン状態(storage_state)の保存先を上書きしたい場合のみ設定（通常は不要）
#YAMATO_B2_STORAGE_STATE=C:\path\to\storage_state.json

# B2 操作をヘッドレスで実行するか（true/false）
#YAMATO_B2_HEADLESS=false

# ---------------------------------------------------------------
# クリックポスト（Yahoo! JAPAN ID でログイン）
# ---------------------------------------------------------------

CLICKPOST_YAHOO_LOGIN_ID=your_yahoo_login_id
CLICKPOST_YAHOO_PASSWORD=your_yahoo_password

# Yahoo! ログインでセキュリティコード入力を求められる場合のみ設定
#CLICKPOST_SECURITYCODE=000000

# クリックポスト操作をヘッドレスで実行するか（true/false。既定 true）
#CLICKPOST_HEADLESS=true
